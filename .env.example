# Credenciales de APLICACION de Finnegans (grant_type=client_credentials).
# Copiar este archivo a ".env" y completar con los valores reales.
# El archivo .env esta en .gitignore y NO debe commitearse ni compartirse.

# --- API de ejecucion (consultas y cambios en Finnegans) ---
FINNEGANS_BASE_URL=https://api.finneg.com
FINNEGANS_CLIENT_ID=tu_client_id
FINNEGANS_CLIENT_SECRET=tu_client_secret
FINNEGANS_WORKSPACE=SOUTEX

# --- MCP de documentacion (catalogo de APIs) ---
# Obtenelas desde Finnegans Developer MCP o desde tu config de Cursor (mcp.json).
FINNEGANS_DOCS_MCP_URL=https://services.finneg.com/api/1/finnegans-developer-mcp/finnegans-api-docs/mcp
FINNEGANS_DOCS_CLIENT_ID=tu_docs_client_id
FINNEGANS_DOCS_SECRET_KEY=tu_docs_secret_key
