# Credenciales de APLICACION de Finnegans (grant_type=client_credentials).
# Copiar este archivo a ".env" y completar con los valores reales.
# El archivo .env esta en .gitignore y NO debe commitearse ni compartirse.

FINNEGANS_BASE_URL=https://api.finneg.com
FINNEGANS_CLIENT_ID=tu_client_id
FINNEGANS_CLIENT_SECRET=tu_client_secret

# Contexto de empresa / espacio de trabajo (si la API lo requiere)
FINNEGANS_WORKSPACE=SOUTEX
